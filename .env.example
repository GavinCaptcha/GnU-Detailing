# Set automatically when Upstash Redis is connected to the Vercel project.
# Pull locally: npm run env:pull   (after npx vercel link)
# Or copy from Vercel → Project → Settings → Environment Variables
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternate names (Vercel KV / Storage connect — any matching pair works)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# STORAGE_URL=          # from Vercel “Connect” (REST endpoint, starts with https://)
# STORAGE_TOKEN=        # add manually from Storage → your DB → .env / Credentials tab
